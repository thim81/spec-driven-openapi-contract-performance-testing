{
  "name": "demo-01-view-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run preview",
    "preview": "node server.js",
    "mock": "inspectr",
    "preview:bump": "bump preview --live ../openapi.yml",
    "preview:scalar": "scalar document serve ../openapi.yml --watch",
    "format": "openapi-format ../openapi.yml --output ../openapi_formatted.yml --keepComments",
    "lint": "redocly lint ../openapi.yml",
    "contract:generate": "portman --cliOptionsFile ./config/portman-cli-options.json --syncPostman true"
  },
  "devDependencies": {
    "@apideck/portman": "^1.35.0",
    "@inspectr/inspectr": "^1.9.1",
    "@redocly/cli": "^2.34.0",
    "@scalar/cli": "^2.0.0",
    "bump-cli": "latest",
    "openapi-format": "^1.33.1",
    "yaml": "^2.9.0"
  }
}
