{
  "name": "02-demo-mock-contract",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "mock": "inspectr",
    "preview:bump": "bump preview --live ../openapi-appearance.yml",
    "lint:openapi": "redocly lint ../openapi-appearance.yml",
    "generate:client": "orval --input ../openapi-appearance.yml --output ./client/api/hero-api.ts --client fetch",
    "contract:generate": "portman --cliOptionsFile ./config/portman-cli-options.json --syncPostman true",
    "contract:test": "portman --cliOptionsFile ./config/portman-cli-options.json --runNewman true --syncPostman false",
    "test": "npm run contract:test"
  },
  "devDependencies": {
    "@apideck/portman": "^1.35.0",
    "@inspectr/inspectr": "^1.9.1",
    "@redocly/cli": "^2.34.0",
    "bump-cli": "latest",
    "orval": "^8.18.0",
    "yaml": "^2.9.0"
  }
}
